#!/bin/bash

# ====================================================
# Repository Update Script (Template)
# ====================================================
# Supports updating all repos at once or selecting
# individual repos from a numbered list.
#
# Setup:
#   1. Copy to /usr/local/bin/update-all-repos
#      sudo cp update-all-repos /usr/local/bin/update-all-repos
#      sudo chmod +x /usr/local/bin/update-all-repos
#
#   2. Edit the REPO_LIST below with your repositories.
#
#   3. Run it: update-all-repos
# ====================================================

# ----------------------------
# Repo Registry (add new repos here)
# ----------------------------
# Format: "Name|Path|post_command"
# post_command is optional (used for build steps etc.)
REPO_LIST=(
    "Linux Skills|/home/administrator/linux-skills|"
    # Add your project repos below:
    # "MyApp|/var/www/html/myapp|"
    # "My Astro Site|/var/www/html/my-astro-site|npm install --production && npm run build"
)

# ----------------------------
# Helper: parse repo entry
# ----------------------------
get_name()  { echo "$1" | cut -d'|' -f1; }
get_path()  { echo "$1" | cut -d'|' -f2; }
get_post()  { echo "$1" | cut -d'|' -f3; }

# ----------------------------
# Function to update a single repository
# ----------------------------
update_repo() {
    local repo_name=$1
    local repo_path=$2
    local post_cmd=$3

    echo "=================================================="
    echo "Updating: $repo_name"
    echo "Location: $repo_path"
    echo "=================================================="
    echo ""
    echo "NOTE: Tracked files will be overwritten."
    echo "      Untracked files will also be removed to avoid conflicts."
    echo ""

    if [ ! -d "$repo_path/.git" ]; then
        echo "  Error: $repo_path is not a Git repository."
        echo ""
        return 1
    fi

    cd "$repo_path" || { echo "  Cannot enter $repo_path"; echo ""; return 1; }

    git config --global --add safe.directory "$repo_path" 2>/dev/null

    echo "Resetting local changes..."
    git reset --hard HEAD
    git clean -fd

    BEFORE=$(git rev-parse HEAD)

    echo "Pulling latest changes..."
    if git pull --rebase; then
        AFTER=$(git rev-parse HEAD)
        echo ""
        echo "  Successfully updated $repo_name"
        current_branch=$(git rev-parse --abbrev-ref HEAD)
        echo "  Branch: $current_branch"
        echo "  Latest commit:"
        git log -1 --oneline

        # Fix permissions for Astro/Node sites (npm install can strip execute bits)
        if [ -d "$repo_path/node_modules/.bin" ]; then
            local non_exec
            non_exec=$(find "$repo_path/node_modules/.bin" -not -perm -u+x 2>/dev/null)
            if [ -n "$non_exec" ]; then
                echo "  Fixing execute permissions in node_modules/.bin/..."
                chmod +x "$repo_path/node_modules/.bin/"*
            fi
        fi

        # Run post-update command if provided and there were changes
        if [ -n "$post_cmd" ]; then
            if [ "$BEFORE" != "$AFTER" ]; then
                echo ""
                echo "  Changes detected, running build step..."
                eval "$post_cmd"
                echo "  Build complete."
            else
                echo "  No changes, skipping build step."
            fi
        fi
    else
        echo ""
        echo "  Error pulling changes for $repo_name!"
        echo "  (Check SSH key authentication or internet connection)"
    fi

    echo ""
}

# ----------------------------
# Display the numbered repo list
# ----------------------------
show_menu() {
    echo "=================================================="
    echo "  Repository Update Tool"
    echo "=================================================="
    echo ""
    echo "  Repositories:"
    echo ""
    local i=1
    for entry in "${REPO_LIST[@]}"; do
        local name=$(get_name "$entry")
        local path=$(get_path "$entry")
        printf "  %2d) %-30s %s\n" "$i" "$name" "$path"
        ((i++))
    done
    echo ""
    echo "   a) Update ALL repositories"
    echo "   q) Quit"
    echo ""
}

# ----------------------------
# Update all repos sequentially
# ----------------------------
update_all() {
    echo ""
    echo "Updating all ${#REPO_LIST[@]} repositories..."
    echo ""
    for entry in "${REPO_LIST[@]}"; do
        update_repo "$(get_name "$entry")" "$(get_path "$entry")" "$(get_post "$entry")"
    done
    echo "All repositories have been processed."
    echo ""
}

# ----------------------------
# Main loop
# ----------------------------
while true; do
    show_menu
    read -p "  Enter your choice: " choice
    echo ""

    case $choice in
        [aA])
            update_all
            read -p "Press Enter to return to menu or type 'q' to quit: " cont
            [[ "$cont" =~ ^[qQ]$ ]] && { echo "Goodbye!"; exit 0; }
            ;;
        [qQ])
            echo "Goodbye!"
            exit 0
            ;;
        ''|*[!0-9]*)
            echo "Invalid choice. Enter a number (1-${#REPO_LIST[@]}), 'a' for all, or 'q' to quit."
            echo ""
            ;;
        *)
            if [ "$choice" -ge 1 ] && [ "$choice" -le "${#REPO_LIST[@]}" ] 2>/dev/null; then
                local_entry="${REPO_LIST[$((choice - 1))]}"
                update_repo "$(get_name "$local_entry")" "$(get_path "$local_entry")" "$(get_post "$local_entry")"

                read -p "Update another repo? (Enter to continue, 'q' to quit): " cont
                [[ "$cont" =~ ^[qQ]$ ]] && { echo "Goodbye!"; exit 0; }
            else
                echo "Invalid choice. Enter a number (1-${#REPO_LIST[@]}), 'a' for all, or 'q' to quit."
                echo ""
            fi
            ;;
    esac
done
